#!/bin/bash
# Launcher for DSA Catalog.app
#
# macOS TCC blocks .app child processes from reading files in ~/Documents
# (iCloud Drive). We work around this by writing a temp script to /tmp
# (not TCC-protected) and opening it in Terminal.app.
#
# This launcher stays alive as long as the server is running so that macOS
# shows the Dock icon dot and the bounce animation on launch.

LOG="$HOME/Library/Logs/DSA-Catalog.log"
mkdir -p "$(dirname "$LOG")"

exec >> "$LOG" 2>&1

echo
echo "=================================================="
echo "Launch attempt: $(date)"

APP_PATH="$(cd "$(dirname "$0")/../.." && pwd)"
PARENT="$(dirname "$APP_PATH")"
echo "App lives at: $APP_PATH"
echo "Working dir : $PARENT"

if [ ! -f "$PARENT/serve.py" ]; then
    echo "ERROR: serve.py not found in $PARENT"
    osascript -e "display alert \"serve.py not found\" message \"Expected it next to DSA Catalog.app in $PARENT.\""
    exit 1
fi

# If the server is already running, just open the browser
if lsof -ti :8765 >/dev/null 2>&1; then
    echo "Server already running on port 8765"
    open "http://localhost:8765/"
else
    # Write a temp launcher to /tmp (not TCC-protected) so Terminal can run it
    TMPSCRIPT="/tmp/dsa-catalog-launch.command"
    cat > "$TMPSCRIPT" << SCRIPT
#!/bin/bash
cd '$PARENT' && exec python3 serve.py
SCRIPT
    chmod +x "$TMPSCRIPT"

    echo "Launching via $TMPSCRIPT in Terminal.app"
    open -a Terminal "$TMPSCRIPT"

    # Wait for server to start
    SERVER_STARTED=false
    for i in 1 2 3 4 5 6 7 8; do
        sleep 1
        if lsof -ti :8765 >/dev/null 2>&1; then
            echo "Server is listening on port 8765"
            open "http://localhost:8765/"
            SERVER_STARTED=true
            break
        fi
    done

    if [ "$SERVER_STARTED" = false ]; then
        echo "ERROR: server did not start within 8 seconds"
        osascript -e 'display alert "DSA Catalog failed to start" message "The server did not start. Check ~/Library/Logs/DSA-Catalog.log for details."'
        exit 1
    fi
fi

# Stay alive while the server is running.
# This keeps the .app process present so macOS shows the Dock dot.
echo "Monitoring server on port 8765 (PID $$)"
while lsof -ti :8765 >/dev/null 2>&1; do
    sleep 5
done

echo "Server stopped — launcher exiting at $(date)"
exit 0
